#!/usr/bin/env bash
set -euo pipefail

STATE_FILE="$HOME/dotfiles/scripts/misc-temp/.presentation-mode"
HYPRIDLE_CONF="$HOME/dotfiles/hypr/.config/hypr/hypridle.conf"

if [[ -f "$STATE_FILE" ]]; then
  rm -f "$STATE_FILE"
  sed -i '0,/timeout = [0-9]*/s/timeout = [0-9]*/timeout = 300/' "$HYPRIDLE_CONF"
else
  touch "$STATE_FILE"
  sed -i '0,/timeout = [0-9]*/s/timeout = [0-9]*/timeout = 86400/' "$HYPRIDLE_CONF"
fi

systemctl --user restart hypridle
